---
const navLinks = [
  { href: '#gallery', label: 'Gallery' },
  { href: '#statement', label: 'Statement' },
  { href: '#about', label: 'About & CV' },
  { href: '#music', label: 'Music' },
  { href: '#events', label: 'Events' },
  { href: '#shop', label: 'Works' },
  { href: '#commissions', label: 'Commissions' },
  { href: '#contact', label: 'Contact' },
];
const mailto = (subject: string, body?: string) =>
  `mailto:durrell.smith03@gmail.com?subject=${encodeURIComponent(subject)}` +
  (body ? `&body=${encodeURIComponent(body)}` : '');

const connectLinks = [
  { href: 'https://www.instagram.com/d_ash_creatives', label: 'Instagram', external: true },
  { href: 'https://substack.com/@durrelllamar/notes', label: 'Substack', external: true },
  { href: mailto('Newsletter signup', 'Hi Durrell,\n\nPlease add me to your newsletter.\n\nName:\n\nThanks,\n'), label: 'Newsletter', external: false },
  { href: mailto('Etsy inquiry'), label: 'Etsy', external: false },
];
const legalLinks = [
  { href: mailto('Privacy question'), label: 'Privacy' },
  { href: mailto('Terms question'), label: 'Terms' },
  { href: mailto('Shipping question'), label: 'Shipping' },
  { href: mailto('Returns question'), label: 'Returns' },
];
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-top">
    <div class="footer-brand">
      <h2>Durrell Lamar Smith / DASH Creatives</h2>
      <p>
        Painter and assemblage artist based in Atlanta, Georgia. Available for gallery
        representation, exhibition, and commissions.
      </p>
    </div>
    <div class="footer-col">
      <h3>Navigate</h3>
      <ul>
        {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <h3>Connect</h3>
      <ul>
        {connectLinks.map((l) => (
          <li>
            <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="footer-col">
      <h3>Legal</h3>
      <ul>
        {legalLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {year} Durrell Lamar Smith / DASH Creatives. All rights reserved.</p>
    <p>Made with ink &amp; intention</p>
  </div>
</footer>
