---
import { artworks } from '@/data/artworks';

const items = artworks.filter((a) => a.inShop);
---

<section id="shop" class="section">
  <div class="section-header">
    <p class="chapter-label">Chapter IV</p>
    <h2 class="section-title">The <em>Shop</em></h2>
  </div>
  <div class="shop-grid">
    {items.map((a) => (
      <div class="shop-card">
        <div class="shop-img">
          <div class="shop-img-inner">
            <img data-artwork={a.id} src={a.image} alt={a.alt} loading="lazy" decoding="async" />
          </div>
          {a.shopBadge && <span class="shop-badge">{a.shopBadge}</span>}
        </div>
        <div class="shop-info">
          <h3 class="shop-name">{a.title}</h3>
          <div class="shop-row">
            <span class="shop-price">{a.status === 'Sold' || a.status === 'Stolen' ? a.status : 'Inquire'}</span>
            <span class="shop-type">{a.shopType ?? a.medium}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div style="margin-top:44px;position:relative;z-index:1;">
    <a href="#contact" class="btn btn-sm">Inquire About Any Work</a>
  </div>
</section>
