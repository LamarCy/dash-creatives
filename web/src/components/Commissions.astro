---
import { tiers } from '@/data/tiers';
---

<section id="commissions" class="section">
  <div class="commission-layout">
    <div>
      <p class="chapter-label">Chapter V</p>
      <h2 class="section-title">Commission <em>a Piece</em></h2>
      <p class="commission-body">
        Every commission starts with a conversation. Whether you're a collector with something
        specific in mind, a gallery seeking a site-responsive work, or someone with a story that
        needs illustrating — write and we'll find the right shape for it together.
      </p>
      <a
        href={`mailto:durrell.smith03@gmail.com?subject=${encodeURIComponent('Commission inquiry')}&body=${encodeURIComponent("Hi Durrell,\n\nI'd like to commission a piece. Here's what I have in mind:\n\n- Subject (person, dog, place, song, feeling):\n- Tier interest (Sketch, Watercolor, Collector's Original, Oil, Editorial):\n- Size preference:\n- Timeline / deadline:\n- A short story (one paragraph is plenty):\n\nThanks,\n")}`}
        class="btn btn-ghost btn-sm"
      >Start a Conversation</a>
    </div>
    <div>
      <div class="tiers">
        {tiers.map((t) => (
          <div class="tier">
            <div class="tier-left">
              <h4>{t.name}</h4>
              <p>{t.detail}</p>
            </div>
            <span class="tier-price">{t.priceLabel}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
