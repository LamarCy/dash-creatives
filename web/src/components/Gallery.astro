---
import { artworks } from '@/data/artworks';

const items = [...artworks].sort((a, b) => b.year - a.year);
---

<section id="gallery" class="section">
  <div class="section-header">
    <p class="chapter-label">Chapter I</p>
    <h2 class="section-title">A Portfolio <em>in Chapters</em></h2>
  </div>
  <div class="timeline">
    {items.map((a) => (
      <div class="t-item">
        <div class="t-year">{a.year}</div>
        <div class="t-card">
          <div class="t-img">
            <img data-artwork={a.id} src={a.image} alt={a.alt} loading="lazy" decoding="async" />
          </div>
          <div class="t-info">
            <p class="t-tag">{a.tag}</p>
            <h3 class="t-title">
              {a.title}
              {a.artist && <em class="t-artist"> ({a.artist})</em>}
            </h3>
            <p class="t-desc">{a.description}</p>
            <div class="t-meta">
              <div class="t-meta-item">Medium<strong>{a.medium}</strong></div>
              {a.size
                ? <div class="t-meta-item">Size<strong>{a.size}</strong></div>
                : a.support && <div class="t-meta-item">Support<strong>{a.support}</strong></div>}
              <div class="t-meta-item">Status<strong>{a.status}</strong></div>
              {a.price && <div class="t-meta-item">Price<strong>{a.price}</strong></div>}
            </div>
            <a
              href={
                a.status === 'Commission — Sold'
                  ? `mailto:durrell.smith03@gmail.com?subject=${encodeURIComponent(`Commission inquiry: similar to ${a.title}`)}&body=${encodeURIComponent(`Hi Durrell,\n\nI'd love to commission a piece in the spirit of "${a.title}" (${a.year}). Here's what I have in mind:\n\n- Subject:\n- Size preference:\n- Timeline:\n\nThanks,\n`)}`
                  : `mailto:durrell.smith03@gmail.com?subject=${encodeURIComponent(`Inquiry: ${a.title}${a.price ? ` (${a.price})` : ''}`)}&body=${encodeURIComponent(`Hi Durrell,\n\nI'm interested in "${a.title}" (${a.year}${a.size ? `, ${a.size}` : ''}${a.price ? `, ${a.price}` : ''}). Could you share availability and next steps?\n\nThanks,\n`)}`
              }
              class="btn btn-sm"
            >
              {a.status === 'Commission — Sold' ? 'Commission Similar' : 'Inquire'}
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .t-artist {
    font-size: 0.75em;
    color: var(--ink-light);
    font-style: italic;
  }
</style>
