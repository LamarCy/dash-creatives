---
import { events } from '@/data/events';
---

<section id="events" class="section">
  <div class="section-header">
    <p class="chapter-label">Chapter III</p>
    <h2 class="section-title">Upcoming <em>Events</em></h2>
  </div>
  <div class="events-grid">
    {events.map((e) => (
      <div class="event-card">
        <p class="event-month">{e.month}</p>
        <div class="event-day">{e.day}</div>
        <h3 class="event-name">{e.name}</h3>
        <p class="event-where">{e.where.join(' / ')}</p>
        <a href="#contact" class="btn btn-sm">RSVP</a>
      </div>
    ))}
  </div>
</section>
