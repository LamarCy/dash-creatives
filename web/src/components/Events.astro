---
import { events } from '@/data/events';
---

<section id="events" class="section">
  <div class="section-header">
    <p class="chapter-label">Chapter III</p>
    <h2 class="section-title">Upcoming <em>Events</em></h2>
  </div>
  <div class="events-grid">
    {events.map((e) => (
      <div class="event-card">
        <p class="event-month">{e.month}</p>
        <div class="event-day event-day-roman">{e.day}</div>
        <h3 class="event-name">{e.name}</h3>
        <p class="event-where" set:html={e.where.join('<br>')} />
        {e.cta && (
          <a
            href={`mailto:durrell.smith03@gmail.com?subject=${encodeURIComponent(`Exhibition inquiry: ${e.name}`)}&body=${encodeURIComponent('Hi Durrell,\n\nI\'m reaching out about an upcoming exhibition opportunity.\n\n')}`}
            class="btn btn-sm"
          >{e.cta}</a>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .event-day-roman { font-size: 2rem; }
</style>
