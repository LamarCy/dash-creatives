---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found — Dash Creatives" description="That page is somewhere else.">
  <section class="section" style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;">
    <div>
      <p class="chapter-label" style="justify-content:center;">404</p>
      <h1 class="section-title">A blank page <em>where a work should be.</em></h1>
      <p style="margin-top:24px;color:var(--ink-mid);">Try the gallery, or write me directly.</p>
      <div style="margin-top:36px;display:flex;gap:14px;justify-content:center;">
        <a href="/" class="btn btn-fill">Home</a>
        <a href="/#contact" class="btn">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
