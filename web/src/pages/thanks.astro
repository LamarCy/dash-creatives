---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank you — Dash Creatives"
  description="Your message has been received."
>
  <section class="section" style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;">
    <div>
      <p class="chapter-label" style="justify-content:center;">Sent</p>
      <h1 class="section-title">Thank you — <em>your note arrived.</em></h1>
      <p style="margin-top:24px;color:var(--ink-mid);">I read every message. Reply usually within 2–3 business days.</p>
      <div style="margin-top:36px;">
        <a href="/" class="btn">Back to the Studio</a>
      </div>
    </div>
  </section>
</BaseLayout>
