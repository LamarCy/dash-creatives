NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4321,https://dash-creatives.netlify.app

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SERVICE_ROLE — server only; NEVER expose to web/ or commit
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email). Leave RESEND_API_KEY blank in dev to skip sending.
RESEND_API_KEY=
CONTACT_NOTIFY_TO=info@secondlifesoftware.com
CONTACT_FROM=hello@dashcreatives.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
